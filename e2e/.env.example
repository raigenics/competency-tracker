# CompetencyIQ E2E Test Environment Configuration
# Copy this file to .env and fill in the values

# Application URL (Vite dev server default)
BASE_URL=http://localhost:5173

# Database connection (for direct seeding/cleanup)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=competencyiq
DB_USER=postgres
DB_PASSWORD=

# Test admin credentials
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Test data ID range (all test data uses IDs >= this value)
SEED_MIN_ID=9000
